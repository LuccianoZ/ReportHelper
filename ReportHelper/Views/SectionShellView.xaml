<UserControl x:Class="ReportHelper.Views.SectionShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Outer grid has two children stacked on top of each other:
         the shell content (always present) and the overlay (shown on cancel). -->
    <Grid>

        <!-- ══ SECTION SHELL CONTENT ══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Grid Grid.Row="0" Background="#1E293B">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding SectionTitle}"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,14"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding SectionCounter}"
                           Foreground="#94A3B8" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Button Grid.Column="2"
                        Content="Cancel Report"
                        Command="{Binding ShowCancelPromptCommand}"
                        Margin="0,8,8,8" Padding="12,6"
                        Foreground="#FCA5A5" Background="Transparent"
                        BorderBrush="#FCA5A5"/>

                <Button Grid.Column="3"
                        Content="Home"
                        Command="{Binding GoHomeCommand}"
                        Margin="0,8,16,8" Padding="12,6"/>
            </Grid>

            <!-- Progress dots -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding ProgressDots}" Margin="20,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="12" Height="12" Margin="4,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#CBD5E1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="True">
                                            <Setter Property="Fill" Value="#2563EB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Section content area -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentSectionViewModel}" Margin="20"/>

            <!-- Action bar -->
            <Grid Grid.Row="3" Margin="20,12">
                <Button Content="Save Draft" Command="{Binding SaveDraftCommand}"
                        HorizontalAlignment="Left" Padding="16,10"/>
                <Button Content="Confirm and Continue →" Command="{Binding ConfirmCommand}"
                        HorizontalAlignment="Right" Padding="16,10"/>
            </Grid>
        </Grid>

        <!-- ══ CANCEL CONFIRMATION OVERLAY ══
             Sits on top of the shell content. Semi-transparent black background
             dims everything behind it, drawing focus to the dialog. -->
        <Grid Background="#B2000000"
              Visibility="{Binding IsCancelPromptVisible, Converter={StaticResource BoolToVis}}">

            <Border Background="White" CornerRadius="12" Padding="40,36"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="400">
                <StackPanel>

                    <TextBlock Text="Are you sure you wish to cancel the report?"
                               FontSize="18" FontWeight="Bold"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="#0F172A" Margin="0,0,0,32"/>

                    <Button Content="No, I do not wish to cancel"
                            Command="{Binding DismissCancelCommand}"
                            Padding="0,14" FontSize="14" Margin="0,0,0,28"/>

                    <TextBlock Text="— or —" HorizontalAlignment="Center"
                               Foreground="#94A3B8" Margin="0,0,0,24"/>

                    <!-- Hold-to-confirm circular button.
                         Three layers share the same 130×130 grid cell:
                         1. Gray track ellipse (static background ring)
                         2. Red progress ellipse (StrokeDashOffset animated in code-behind)
                         3. Transparent hit ellipse (captures mouse events) -->
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="130" Height="130" Margin="0,0,0,8">

                            <!-- Static gray track — always fully visible -->
                            <Ellipse Stroke="#E2E8F0" StrokeThickness="7" Fill="Transparent"/>

                            <!-- Animated red ring. StrokeDashArray=55.5 makes one dash
                                 equal to the circumference of this circle (130px diameter,
                                 7px stroke, centre radius 61.5px → 386px → 55.5 units).
                                 StrokeDashOffset=55.5 hides it completely at rest.
                                 The code-behind animates this to 0 over 4 seconds. -->
                            <Ellipse x:Name="ProgressRing"
                                     Stroke="#DC2626" StrokeThickness="7" Fill="Transparent"
                                     StrokeDashArray="55.5" StrokeDashOffset="55.5"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <!-- -90° rotates the start point to 12 o'clock -->
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Label — IsHitTestVisible=False so it doesn't block mouse events -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                <TextBlock Text="Yes, Confirm" TextAlignment="Center"
                                           FontWeight="Bold" Foreground="#DC2626" FontSize="13"/>
                                <TextBlock Text="Cancel" TextAlignment="Center"
                                           FontWeight="Bold" Foreground="#DC2626" FontSize="13"/>
                            </StackPanel>

                            <!-- Transparent hit area — receives press and release events.
                                 Must come last so it sits on top of the other layers. -->
                            <Ellipse x:Name="HoldTarget" Fill="Transparent" Cursor="Hand"
                                     PreviewMouseLeftButtonDown="HoldCancelButton_MouseDown"
                                     PreviewMouseLeftButtonUp="HoldCancelButton_MouseUp"/>
                        </Grid>

                        <TextBlock Text="Hold for 4 seconds to confirm"
                                   HorizontalAlignment="Center"
                                   FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
